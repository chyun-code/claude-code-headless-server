{
  "name": "claude-code-headless-server",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "description": "OpenCode-compatible HTTP server backed by Claude Code headless mode",
  "bin": {
    "claude-headless-server": "scripts/claude-headless-server.sh"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bun run tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.10.7",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "typescript": "^5.8.3"
  }
}
